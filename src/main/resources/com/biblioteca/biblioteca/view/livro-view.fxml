<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.biblioteca.biblioteca.controller.LivroController"
      spacing="15">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Cadastro de Livros" styleClass="titulo-secao"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Título:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="tituloField" promptText="Título do livro"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Autor:"  GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="autorField" promptText="Autor"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="ISBN:"   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="isbnField" promptText="ISBN (opcional)"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <Button text="Cadastrar Livro" onAction="#handleCadastrar"/>
    <Label fx:id="mensagemLabel"/>

    <Separator/>
    <Label text="Livros Cadastrados" styleClass="subtitulo-secao"/>
    <TableView fx:id="livrosTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="colTitulo"     text="Título"          prefWidth="200"/>
            <TableColumn fx:id="colAutor"      text="Autor"           prefWidth="150"/>
            <TableColumn fx:id="colIsbn"       text="ISBN"            prefWidth="120"/>
            <TableColumn fx:id="colDisponivel" text="Disponibilidade" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button fx:id="btnExcluir" text="Excluir Livro Selecionado"
                styleClass="btn-danger"
                onAction="#handleExcluir"/>
    </HBox>
</VBox>
